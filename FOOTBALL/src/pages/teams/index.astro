---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const teams = [
  { name: "Manchester City", league: "Premier League", country: "England", founded: 1880, logo: "🏴󠁧󠁢󠁥󠁮󠁧󠁿", color: "from-sky-500 to-blue-600" },
  { name: "Real Madrid", league: "La Liga", country: "Spain", founded: 1902, logo: "🇪🇸", color: "from-yellow-500 to-yellow-600" },
  { name: "Barcelona", league: "La Liga", country: "Spain", founded: 1899, logo: "🇪🇸", color: "from-blue-500 to-red-500" },
  { name: "Liverpool", league: "Premier League", country: "England", founded: 1892, logo: "🏴󠁧󠁢󠁥󠁮󠁧󠁿", color: "from-red-500 to-red-600" },
  { name: "Bayern Munich", league: "Bundesliga", country: "Germany", founded: 1900, logo: "🇩🇪", color: "from-red-600 to-red-700" },
  { name: "Paris Saint-Germain", league: "Ligue 1", country: "France", founded: 1970, logo: "🇫🇷", color: "from-blue-700 to-red-500" },
  { name: "Juventus", league: "Serie A", country: "Italy", founded: 1897, logo: "🇮🇹", color: "from-gray-800 to-black" },
  { name: "AC Milan", league: "Serie A", country: "Italy", founded: 1899, logo: "🇮🇹", color: "from-red-700 to-black" },
  { name: "Arsenal", league: "Premier League", country: "England", founded: 1886, logo: "🏴󠁧󠁢󠁥󠁮󠁧󠁿", color: "from-red-500 to-red-600" },
  { name: "Chelsea", league: "Premier League", country: "England", founded: 1905, logo: "🏴󠁧󠁢󠁥󠁮󠁧󠁿", color: "from-blue-600 to-blue-700" },
  { name: "Borussia Dortmund", league: "Bundesliga", country: "Germany", founded: 1909, logo: "🇩🇪", color: "from-yellow-500 to-black" },
  { name: "Inter Milan", league: "Serie A", country: "Italy", founded: 1908, logo: "🇮🇹", color: "from-blue-600 to-black" },
];
---

<Layout title="Teams" description="Discover football teams from around the world">
  <Header />

  <div class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <div class="bg-gradient-to-r from-green-700 to-green-600 py-16">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Top Football Teams</h1>
        <p class="text-green-100 text-lg max-w-2xl mx-auto">
          Explore the world's most prestigious football clubs
        </p>
      </div>
    </div>

    <!-- Teams Grid -->
    <div class="max-w-7xl mx-auto px-4 py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {teams.map((team) => (
          <a 
            href={`/teams/${team.name.toLowerCase().replace(/\s+/g, '-')}`}
            class="group bg-white rounded-2xl p-6 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          >
            <div class="flex items-center space-x-4">
              <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${team.color} flex items-center justify-center text-3xl shadow-lg group-hover:scale-110 transition-transform`}>
                {team.logo}
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 text-lg group-hover:text-green-600 transition-colors">
                  {team.name}
                </h3>
                <p class="text-sm text-gray-500">{team.league}</p>
                <div class="flex items-center text-xs text-gray-400 mt-1">
                  <span>{team.country}</span>
                  <span class="mx-2">•</span>
                  <span>Founded {team.founded}</span>
                </div>
              </div>
              <svg class="w-6 h-6 text-gray-300 group-hover:text-green-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <Footer />
</Layout>
