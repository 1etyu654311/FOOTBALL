---
// Recent Posts Component
// Displays a list of recent blog posts in the sidebar

interface Props {
  limit?: number;
  lang?: string;
}

const { limit = 5, lang = 'en' } = Astro.props;

const allPosts = await import.meta.glob('/src/content/blog/*.md', { eager: true });

const posts = Object.entries(allPosts)
  .map(([path, post]) => ({
    ...post,
    slug: path.split('/').pop()?.replace('.md', ''),
  }))
  .filter(post => post.slug)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, limit);
---

<div class="recent-posts">
  <h3>Recent Posts</h3>
  <ul class="posts-list">
    {posts.map(post => (
      <li>
        <a href={`/${lang}/blog/${post.slug}/`}>
          <span class="post-category">{post.data.category}</span>
          <h4>{post.data.title}</h4>
          <time datetime={post.data.pubDate}>
            {new Date(post.data.pubDate).toLocaleDateString(lang, {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .recent-posts {
    background: rgb(var(--card-bg));
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 2rem;
  }

  .recent-posts h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: rgb(var(--text-main));
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .posts-list li {
    margin-bottom: 1rem;
  }

  .posts-list li:last-child {
    margin-bottom: 0;
  }

  .posts-list a {
    text-decoration: none;
    color: rgb(var(--text-main));
    transition: color 0.2s ease;
  }

  .posts-list a:hover {
    color: rgb(var(--accent));
  }

  .post-category {
    display: inline-block;
    background: rgb(var(--accent));
    color: rgb(var(--white));
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .posts-list h4 {
    font-size: 0.95rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }

  .posts-list time {
    font-size: 0.85rem;
    color: rgb(var(--text-secondary));
  }
</style>
